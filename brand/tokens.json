{
  "$schema": "design-tokens",
  "meta": {
    "name": "Brand Style Kit",
    "version": "1.0",
    "source": "2025 Brand Kit — PMI modified presentation template, 'Colors and fonts' slide",
    "usageRatio": { "primary": 0.5, "secondary": 0.3, "accent": 0.2 }
  },
  "color": {
    "violet": {
      "role": "primary / logo / main brand color (Accent 1)",
      "main": "#461DA3",
      "ramp": ["#D4C6F5", "#A98EEC", "#8158E3", "#36177B", "#270F53"]
    },
    "aqua": {
      "role": "secondary (Accents 2-3)",
      "tealBlue": {
        "main": "#44789B",
        "ramp": ["#C9EFFE", "#9ADDFE", "#79CDFD", "#345B74", "#233E4F"]
      },
      "skyCyan": {
        "main": "#6CBEDE",
        "ramp": ["#D5F6FE", "#B0EBFC", "#92E2FA", "#508EA6", "#37606F"],
        "textRule": "dark text only — white on #6CBEDE fails WCAG (2.09:1)"
      }
    },
    "tangerine": {
      "role": "accent / highlight / CTA (Accents 4-5)",
      "burntOrange": {
        "main": "#B83713",
        "ramp": ["#A53311", "#8A2B0D", "#5C2009", "#311004", "#180601"]
      },
      "brightOrange": {
        "main": "#E0611F",
        "ramp": ["#F6DECF", "#EFBF9F", "#E89F71", "#B0470A", "#753205"],
        "textRule": "white text at large sizes only (3.56:1)"
      }
    },
    "saddle": {
      "role": "accent / warm neutral (Accent 6)",
      "main": "#B29478",
      "ramp": ["#EFE9E3", "#E0D4C8", "#D0BEAC", "#906E4E", "#614A36"],
      "textRule": "dark text only — white on #B29478 fails WCAG (2.84:1)"
    },
    "neutral": {
      "light": {
        "main": "#F6F4EF",
        "ramp": ["#E4DDCE", "#C8BB9E", "#998355", "#4E442E", "#242016"]
      },
      "dark": {
        "main": "#7F7F7F",
        "ramp": ["#E5E5E5", "#CBCBCB", "#B1B1B1", "#606060", "#424242"]
      }
    },
    "semantic": {
      "bgLight": "#F6F4EF",
      "bgDark": "#270F53",
      "textOnLight": "#242016",
      "textOnDark": "#F6F4EF",
      "eyebrow": "#461DA3",
      "cta": "#E0611F",
      "swipeCue": "#E0611F"
    }
  },
  "typography": {
    "heading": { "family": "Aptos", "weight": 700 },
    "body": { "family": "Aptos", "weight": 400 },
    "fallbackStack": "Aptos, Inter, 'Helvetica Neue', Arial, sans-serif",
    "case": "sentence",
    "slides": {
      "h1": { "sizePt": 48, "lineHeight": 1.1 },
      "subtitle": { "sizePt": 30, "lineHeight": 1.2, "color": "#461DA3" },
      "h2": { "sizePt": 28, "lineHeight": 1.2 },
      "h3": { "sizePt": 20, "lineHeight": 1.3 },
      "body": { "sizePt": 16, "lineHeight": 1.45 },
      "caption": { "sizePt": 11, "lineHeight": 1.3 }
    },
    "carousel1080x1350": {
      "hook": { "sizePx": [88, 110], "lineHeight": 1.05 },
      "headline": { "sizePx": [64, 72], "lineHeight": 1.1 },
      "body": { "sizePx": [36, 42], "lineHeight": 1.35 },
      "eyebrow": { "sizePx": 28, "lineHeight": 1.2 },
      "pageNumber": { "sizePx": [24, 28], "lineHeight": 1.0 },
      "minimumTextPx": 28
    }
  },
  "layout": {
    "baseUnitPx": 8,
    "socialCanvas": { "width": 1080, "height": 1350, "ratio": "4:5" },
    "safeMarginPx": 80,
    "topClearZonePx": 120,
    "bottomClearZonePx": 180,
    "cornerRadius": { "card": 16, "button": 999, "image": 0 },
    "grid": { "slides": 12, "social": { "columns": 6, "columnPx": 72, "gutterPx": 24 } }
  },
  "logo": {
    "primaryColor": "#461DA3",
    "knockoutOnDark": ["#FFFFFF", "#D4C6F5"],
    "approvedBackgrounds": ["#F6F4EF", "#FFFFFF", "#D4C6F5", "#C9EFFE", "#EFE9E3"],
    "minWidthPx": 120,
    "clearspace": "logo x-height on all sides"
  },
  "contrast": {
    "standard": "WCAG 2.1 AA (4.5:1 body, 3:1 large)",
    "verified": {
      "#FFFFFF_on_#461DA3": 10.69,
      "#FFFFFF_on_#270F53": 16.41,
      "#FFFFFF_on_#44789B": 4.77,
      "#FFFFFF_on_#6CBEDE": 2.09,
      "#270F53_on_#6CBEDE": 7.86,
      "#FFFFFF_on_#B83713": 5.84,
      "#FFFFFF_on_#E0611F": 3.56,
      "#E0611F_on_#270F53": 4.61,
      "#FFFFFF_on_#B29478": 2.84,
      "#FFFFFF_on_#7F7F7F": 4.0,
      "#242016_on_#F6F4EF": 14.77,
      "#461DA3_on_#F6F4EF": 9.72
    }
  }
}
